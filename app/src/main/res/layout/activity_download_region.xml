<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/darkBackground">

    <org.osmdroid.views.MapView
        android:id="@+id/map_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surfaceColor"
        android:padding="12dp">

        <Button
            android:id="@+id/btn_eastern_pa_preset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/eastern_pa_preset"
            android:backgroundTint="@color/colorPrimary" />

        <RadioGroup
            android:id="@+id/rg_tile_source"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <RadioButton
                android:id="@+id/rb_standard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/tile_source_standard"
                android:textColor="@color/textPrimary"
                android:buttonTint="@color/colorAccent"
                android:checked="true" />

            <RadioButton
                android:id="@+id/rb_cyclosm"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/tile_source_cyclosm"
                android:textColor="@color/textPrimary"
                android:buttonTint="@color/colorAccent" />

        </RadioGroup>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="@string/min_zoom"
                android:textColor="@color/textPrimary" />

            <SeekBar
                android:id="@+id/seekbar_min_zoom"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="7"
                android:progress="2" />

            <TextView
                android:id="@+id/tv_min_zoom"
                android:layout_width="30dp"
                android:layout_height="wrap_content"
                android:text="12"
                android:textColor="@color/colorAccent"
                android:gravity="center" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="@string/max_zoom"
                android:textColor="@color/textPrimary" />

            <SeekBar
                android:id="@+id/seekbar_max_zoom"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="7"
                android:progress="6" />

            <TextView
                android:id="@+id/tv_max_zoom"
                android:layout_width="30dp"
                android:layout_height="wrap_content"
                android:text="16"
                android:textColor="@color/colorAccent"
                android:gravity="center" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_estimate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/textSecondary"
            android:textSize="12sp" />

        <ProgressBar
            android:id="@+id/progress_download"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:max="100" />

        <TextView
            android:id="@+id/tv_eta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/textSecondary"
            android:textSize="11sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_download"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/download_tiles"
            android:backgroundTint="@color/colorAccent" />

    </LinearLayout>

</LinearLayout>
